flowchart TB
  subgraph NAS[Synology NAS]
    subgraph VOL[永続ボリューム]
      V1["toolbox ボリューム<br/>（ソース + SQLite DB）"]
      V2["infra/secrets ボリューム<br/>（暗号化シークレット + マスター鍵）"]
    end
    subgraph DOCKER[Docker]
      WEB["central-sports-web<br/>restart: always<br/>TZ=Asia/Tokyo"]
    end
    V1 -- rw bind mount --> WEB
    V2 -- ro bind mount --> WEB
  end
  PORT["LAN 内限定ポート<br/>（既存サービスと衝突しない番号<br/>をデプロイ時に割当）"]
  WEB --- PORT
