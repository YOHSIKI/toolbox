# 実行時設定のサンプル。必要に応じてコピーして使う。
# 本番 POST を有効化するには CSW_DRY_RUN=false
CSW_DRY_RUN=true

# Basic 認証（本番運用では必ず上書きする）
CSW_BASIC_AUTH_USER=admin
CSW_BASIC_AUTH_PASSWORD=changeme
CSW_BASIC_AUTH_ENABLED=true

# シークレット
CSW_SECRETS_DIR=/workspace/.secrets
CSW_SECRETS_GROUP=central-sports

# 既定店舗
CSW_DEFAULT_STUDIO_ID=79
CSW_DEFAULT_STUDIO_ROOM_ID=177
CSW_DEFAULT_STUDIO_NAME=セントラルフィットネスクラブ府中

# Discord Webhook（空なら通知抑止）
CSW_DISCORD_WEBHOOK_URL=

# スケジューラ
CSW_SCHEDULER_ENABLED=true
CSW_AUTO_BOOKING_HOUR=9
CSW_AUTO_BOOKING_MINUTE=0
CSW_LOGIN_WARMUP_HOUR=8
CSW_LOGIN_WARMUP_MINUTE=55
